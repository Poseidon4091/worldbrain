# worldbrain configuration.
#
# Provider settings here only SEED the database `settings` row on first boot. After that the
# settings UI is authoritative, and changing these has no effect. API keys are the exception:
# they are read from env on every request and never stored in the database, so the settings UI
# has nothing sensitive to display.

# ── Required ─────────────────────────────────────────────────────────────────
# Must point at PostgreSQL with the pgvector extension available.
DATABASE_URL=postgresql://worldbrain:changeme@localhost:5432/worldbrain

# Used by docker-compose.yml to provision the database container.
POSTGRES_USER=worldbrain
POSTGRES_PASSWORD=changeme
POSTGRES_DB=worldbrain

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
APP_URL=http://localhost:8080

# Owner id every world is scoped to. Change only when migrating data written under another id.
WORLDBRAIN_OWNER_ID=worldbrain-owner

# ── Providers (seed values) ──────────────────────────────────────────────────
# EMBEDDING_ROUTER: openai | openrouter | openrouter_external | ollama | voyage
# NOTE: model-gateway providers like OpenCode Zen serve chat models only, not embeddings —
# keep embeddings on a provider that has an /embeddings endpoint (OpenAI, OpenRouter, Voyage).
EMBEDDING_ROUTER=openrouter
# Must be a 1024-dimension model: the pgvector column is vector(1024) and changing dimension
# requires a column migration plus a full re-embed (see docs/01_architecture.md §9).
# For a router other than plain "openai", use that provider's model id form (e.g. the
# "openai/..." prefix on OpenRouter).
EMBEDDING_MODEL=openai/text-embedding-3-small

# LLM_ROUTER: openai | openrouter | nanogpt | custom
# Use LLM_MODEL in the chosen provider's id form ("openai/gpt-4o-mini" on OpenRouter, a bare id
# on OpenAI). A wrong-form id fails with model-not-found.
LLM_ROUTER=openrouter
LLM_MODEL=openai/gpt-4o-mini

# ── API keys ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENROUTER_API_KEY=
VOYAGE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# `custom` LLM router — any OpenAI-compatible /chat/completions endpoint. For OpenCode Zen:
#   LLM_ROUTER=custom
#   LLM_BASE_URL=https://opencode.ai/zen/v1
#   LLM_API_KEY=<key from https://opencode.ai/auth>
#   LLM_MODEL=<a Zen model id from your dashboard>
LLM_BASE_URL=
LLM_API_KEY=
