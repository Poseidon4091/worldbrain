# worldbrain configuration.
#
# Provider settings here only SEED the database `settings` row on first boot. After that the
# settings UI is authoritative, and changing these has no effect. API keys are the exception:
# they are read from env on every request and never stored in the database, so the settings UI
# has nothing sensitive to display.

# ── Required ─────────────────────────────────────────────────────────────────
# Must point at PostgreSQL with the pgvector extension available.
DATABASE_URL=postgresql://worldbrain:changeme@localhost:5432/worldbrain

# Used by docker-compose.yml to provision the database container.
POSTGRES_USER=worldbrain
POSTGRES_PASSWORD=changeme
POSTGRES_DB=worldbrain

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
APP_URL=http://localhost:8080

# Owner id every world is scoped to. Change only when migrating data written under another id.
WORLDBRAIN_OWNER_ID=worldbrain-owner

# ── Providers (seed values) ──────────────────────────────────────────────────
# EMBEDDING_ROUTER: openai | openrouter | openrouter_external | ollama | voyage
EMBEDDING_ROUTER=openai
# Must be a 1024-dimension model: the pgvector column is vector(1024) and changing dimension
# requires a column migration plus a full re-embed (see docs/01_architecture.md §9).
EMBEDDING_MODEL=text-embedding-3-small

LLM_ROUTER=openai
LLM_MODEL=gpt-4o-mini

# ── API keys ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENROUTER_API_KEY=
VOYAGE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
