// worldbrain — persistent world/context store.
// Originally extracted from Aria's lorebook subsystem; all chat-app coupling (User, Chat,
// ChatGraph, ChatSummary, Message, personas) has been stripped. External anchor columns are plain
// strings so no chat/transcript store is implied.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

/// Per-owner runtime configuration, edited through the settings UI and seeded from env on first
/// boot. This is worldbrain's OWN settings model — not a port of Aria's — and exists so the daemon
/// can be reconfigured (embedding provider, ingest model) without a restart or a redeploy.
///
/// In the default single-user deployment there is exactly one row, keyed by the fixed owner id.
model Settings {
  userId String @id

  // Embedding provider used for indexing + query embedding.
  embeddingEnabled Boolean @default(true)
  embeddingRouter  String  @default("openai")
  embeddingModel   String?

  // LLM used by the ingest/extraction pass (OpenAI-compatible; see routerDispatch.ts).
  llmRouter String  @default("openai")
  llmModel  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

/// A book: one persistent context store, typically one per project.
model World {
  id         String   @id @default(uuid())
  userId     String
  title      String
  group      String?  @map("group_name")
  tags       String[] @default([])
  /// Locks the book against agent writes. Defaults FALSE: worldbrain's whole premise is that any
  /// connected tool can contribute, not just whoever created the book. Set true only for imported
  /// material you want treated as canon (a spec, a vendor doc) that agents may read but not edit.
  ///
  /// Enforced in worldWrite.applyDeltaTransactional. Was `isReference` when ported from Aria, where
  /// the equivalent check lived in the chat pipeline — which the port stripped, leaving the column
  /// silently unenforced.
  readOnly   Boolean  @default(false)
  // When true: entries only inject when their tags are explicitly mentioned (tag-gated).
  tagGated   Boolean  @default(false)
  checkpoint Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items       WorldItem[]
  checkpoints WorldCheckpoint[]
  memories    Memory[]

  @@index([userId])
  @@map("worlds")
}

/// Relational, embeddable projection of a book's checkpoint entities (+ passages).
model WorldItem {
  id              String  @id @default(uuid())
  worldId         String
  world           World   @relation(fields: [worldId], references: [id], onDelete: Cascade)
  sourceId        String?
  key             String // entity name / stable key
  // Storage bucket. Names are narrative in origin; the extraction prompt maps project
  // vocabulary onto them (component/area/resource/decision/event) — see prompt/constants.ts.
  type            String // character, location, item, knowledge, event, passage, chronology, ...
  content         String // stringified rich content
  importanceScore Float   @default(1.0)

  // Canon position for temporally-gated retrieval.
  canonBook    Int?
  canonChapter Int?

  embedding      Unsupported("vector(1024)")?
  embeddingModel String?
  embeddedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([worldId, key])
  @@index([worldId])
  @@index([sourceId])
  @@map("world_items")
}

/// Point-in-time snapshot of a book's checkpoint JSON, keyed to an external anchor id.
model WorldCheckpoint {
  id        String   @id @default(uuid())
  worldId   String
  world     World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  messageId String // external anchor id (no Message relation in worldbrain)
  data      Json
  summary   String?
  createdAt DateTime @default(now())

  @@index([worldId])
  @@index([messageId])
  @@map("world_checkpoints")
}

/// Durable standalone facts produced by the ingest's memory delta, retrievable by vector search.
/// Distinct from World entities: a Memory is a free-standing statement, not a card about a named
/// thing.
///
/// Aria's persona/chat scoping columns (chatId, userProfileId, ariaPersonaId, isRoleplay, nsfw)
/// were removed — worldbrain has no personas or chats, nothing ever set them, and the matching
/// `memoryScope` query branch in findSimilarMemories was dead code.
model Memory {
  id               String    @id @default(uuid())
  userId           String
  worldId          String?
  world            World?    @relation(fields: [worldId], references: [id])
  kind             String    @default("fact")
  status           String    @default("ACCEPTED")
  content          String
  confidence       Float?
  reasoning        String?
  sourceMessageIds String[]  @default([])
  actualTags       Json      @default("[]")
  suggestedTags    Json      @default("[]")
  enabled          Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  metadata         Json      @default("{}")

  importanceScore  Float     @default(2.0)
  referenceCount   Int       @default(1)
  lastReferencedAt DateTime?
  parentMemoryId   String?

  embedding      Unsupported("vector(1024)")?
  embeddingModel String?
  embeddedAt     DateTime?

  @@index([userId, kind])
  @@index([userId, status])
  @@index([worldId])
  @@map("memories")
}
